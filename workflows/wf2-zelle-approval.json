          "mode": "byName",
          "value": "Pending Leads"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "Lead ID",
              "lookupValue": "={{ $json.leadId }}"
            }
          ]
        },
        "options": {}
