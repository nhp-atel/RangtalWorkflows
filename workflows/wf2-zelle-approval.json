    {
      "parameters": {
        "jsCode": "const query = $input.first().json.query || {};\nconst leadId = query.leadId || '';\nconst token = query.token || '';\n\nif (!leadId || !token) {\n  return [{ json: { valid: false, reason: 'missing_params' } }];\n}\n\nreturn [{ json: { leadId, token, valid: true } }];"
      },
      "id": "a1b2c3d4-1111-4aaa-bbbb-000000000002",
      "name": "Extract Query Params",
      "type": "@n8n/n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
