    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst lead = items.length > 0 ? items[0].json : null;\nconst queryData = $('Extract Query Params').first().json;\n\nif (!lead || !lead['Lead ID']) {\n  return [{ json: { action: 'error', reason: 'lead_not_found' } }];\n}\n\nif (lead['Status'] === 'CONFIRMED') {\n  return [{ json: { action: 'already_done', leadId: lead['Lead ID'] } }];\n}\n\nif (lead['Approval Token'] !== queryData.token) {\n  return [{ json: { action: 'error', reason: 'invalid_token' } }];\n}\n\nreturn [{\n  json: {\n    action: 'approve',\n    leadId: lead['Lead ID'],\n    name: lead['Name'],\n    phone: lead['Phone'],\n    email: lead['Email'],\n    amount: lead['Amount'],\n    paymentMethod: lead['Payment Method'],\n    subscriptionPeriod: lead['Subscription Period']\n  }\n}];"
      },
